[gd_scene load_steps=2 format=2]

[sub_resource type="GDScript" id=1]
script/source = "extends GraphNode

var current_path := \"\"

signal file_dialog_request(source_node)


func set_loaded_path(new_path):
	current_path = new_path
	$Wrapper/LineEdit.set_text(new_path)


func _on_GraphNode_close_request():
	queue_free()


func _on_Button_pressed():
	emit_signal(\"file_dialog_request\", get_instance_id())
"

